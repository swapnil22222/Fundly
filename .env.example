# ── React App ──────────────────────────────────────────────────
# Deployed contract address on Sepolia
REACT_APP_CONTRACT_ADDRESS=0x75538F5f2B346029d88DFC3EBDae1165bF8DF3e1

# ── Hardhat / Deployment ───────────────────────────────────────
# Sepolia RPC (get free one from Alchemy or Infura)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Deployer wallet private key (never commit the real one!)
PRIVATE_KEY=0xYourPrivateKeyHere

# Etherscan API key (for contract verification)
ETHERSCAN_API_KEY=YourEtherscanKeyHere

# ── IPFS / Pinata (optional) ────────────────────────────────────
REACT_APP_PINATA_JWT=YourPinataJWTHere
